<!-- Advanced Task 2 -->
<!DOCTYPE html>
<html>
  
    <head>
        <!-- Tab title -->
        <title>CyberBreach Labs - Advanced: Task 2</title>
        <!-- Link to stylesheet -->
        <link rel="stylesheet" href="/static/style.css">
        <!-- Link to JavaScript file -->
        <script src="{{ url_for('static', filename='labs.js') }}"></script>
    </head>
  
    <body>
        <!-- Task number and difficulty -->
        <h1>Advanced: Task 2</h1>
        
        <!-- Navigation -->      
        <nav>
            <a href="/">Home</a>
            <a href="/account">Account</a>
            <a href="/labs">Labs</a>
            <!-- Added link: difficulty page -->
            <a href="/labs/advanced">Advanced Labs</a>
        </nav>

        <div class="description">
            <!-- Task title -->
            <h2>Cryptographic Failures</h2>
            <!-- Descition of vulnerability and task -->
            <p>Cryptography is the practice of protecting data using algorithms that transform readable data into ciphertext <br>
                using cryptographic keys to ensure that only authorised users have access to it. However, these algorithms can <br>
                fail, exposing vulnerabilities to be exploited by attackers, seeking to access sensitive data.<br>
            In this lab, you will have access to the web application for Book Nook, where users can browse, buy <br>
            and wishlist books. However, the site has been deployed too early and the developers were very sloppy.<br> 
            Sensitive data was not protected properly and there was a data breach. A username and encrypted password were leaked.
            <br><br>
            Task: Capture the Flag ! Just login to find it. You can create a Python script to decipher the password.
            <br><br>
             > user email: marylamb@booknook.com<br>
             > encrypted password: pbbxvrqbhtu <br>
            </p> 
            <!-- Button to start lab, opens a new tab -->
            <a href="/labs/advanced/A2/A2task" target="_blank" class="button">Start Lab</a>
            
            <!-- Flag submission -->
            <br><br>Submit Flag:
            <form method="POST" action="/submitFlag">
                <!-- Task ID for progress bar -->
                <input type="hidden" name="taskID" value="A2">
                <!-- Correct flag value -->
                <input type="hidden" name="taskFlag" value="crypto_failures_5df71">
                <!-- User flag submission -->
                <input type="text" name="userFlag" placeholder="FLAG" autocomplete="off" required>
                <!-- Submission Button -->
                <button type="submit" class="button">Submit Flag</button>
            </form>

            <!-- Jinja2: Flash messages -->
            <!-- Calls Flash function [backend] and pulls messages from storage -->
            {% with messages = get_flashed_messages(with_categories=true) %} 
                {% for category, message in messages %}
                    <!-- If error message, display in red. If not, display in green -->
                    <p class="{{ 'errorMessage' if category == 'error' else 'successMessage' }}">{{ message }}</p>
                {% endfor %}
            {% endwith %}
            
        </div>

        <div class="description">
            <!-- Hints -->
            <h2>Hints</h2>
            <!-- Button clicked => call revealHint function from .js file -->
            <button class="button" onclick="revealHint()">Reveal Hint?</button>
            <div id="hints"> 
                <!-- Each hint is hidden, displayed only when function is called -->
                <p class="hint" style="display: none;">Hint 1: Your script should loop for each character in the alphabet</p>
                <p class="hint" style="display: none;">Hint 2: Your script should shift each character by 1 place. The next loop should take the new hash and shift it by one place again</p>
            </div>
        
        </div>

        <!-- Solution -->
        <div class="description">
            <h2>Solution</h2>
            <!-- Button clicked => call revealSolution function from .js file -->
            <button class="button" onclick="revealSolution()">Reveal Solution</button>
            <!-- Solution is hidden, displayed only when function is called -->
            <div id="solution" style="display: none;">
                <!-- Solution text -->
                <p> 
                > Create a python script to shift the characters one at a time until a readable password is found. <br>   
                > Here is an example script: <a href="/static/A2.py" style="text-decoration: underline; color: blue;">I2 solution script</a></p>

        </div>
   
    </body>

</html>
