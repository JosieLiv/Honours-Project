<!-- Intermediate Task 3 -->
<!DOCTYPE html>
<html>
  
    <head>
        <!-- Tab title -->
        <title>CyberBreach Labs - Intermediate: Task 3</title>
        <!-- Link to stylesheet -->
        <link rel="stylesheet" href="/static/style.css">
        <!-- Link to JavaScript file -->
        <script src="{{ url_for('static', filename='labs.js') }}"></script>
    </head>
  
    <body>
        <!-- Task number and difficulty -->
        <h1>Intermediate: Task 3</h1>
        
        <!-- Navigation -->      
        <nav>
            <a href="/">Home</a>
            <a href="/account">Account</a>
            <a href="/labs">Labs</a>
            <!-- Added link: difficulty page -->
            <a href="/labs/intermediate">Intermediate Labs</a>
        </nav>

        <div class="description">
            <!-- Task title -->
            <h2>Injection</h2>
            <!-- Descition of vulnerability and task -->
            <p>Injection vulnerabilities occur when an application improperly validates or filters user <br>
                input before it is processed, allowing an attacher to 'inject' malicious code. Once the <br>
                backend executes this code, the system can be compromised and data can be leaked. Cross Site scripting <br>
                (XSS) is when an attacker injects malicious scripts into a website with improper input validation and a <br>
                browser then executes those scripts to hijack sessions and steal user credentials.  <br>
                <br>
            In this lab, you will have access to the web application for Book Nook, where users can browse, buy <br>
            and wishlist books. However, the site has been deployed too early and the developers were very sloppy.<br> 
            User input is not sanitised so any HTML or JavaScript can be entered then executed by the browser.
            <br><br>
            Task: Capture the Flag ! Inject a JavaScript alert payload into the search bar.
            <br><br>
            </p>
            <!-- Button to start lab, opens a new tab -->
            <a href="/labs/intermediate/I3/I3task" target="_blank" class="button">Start Lab</a>
            
            <!-- Flag submission -->
            <br><br>Submit Flag:
            <form method="POST" action="/submitFlag">
                <!-- Task ID for progress bar -->
                <input type="hidden" name="taskID" value="I3">
                <!-- Correct flag value -->
                <input type="hidden" name="taskFlag" value="injection_x33jk">
                <!-- User flag submission -->
                <input type="text" name="userFlag" placeholder="FLAG" autocomplete="off" required>
                <!-- Submission Button -->
                <button type="submit" class="button">Submit Flag</button>
            </form>

            <!-- Jinja2: Flash messages -->
            <!-- Calls Flash function [backend] and pulls messages from storage -->
            {% with messages = get_flashed_messages(with_categories=true) %} 
                {% for category, message in messages %}
                    <!-- If error message, display in red. If not, display in green -->
                    <p class="{{ 'errorMessage' if category == 'error' else 'successMessage' }}">{{ message }}</p>
                {% endfor %}
            {% endwith %}
            
        </div>

        <div class="description">
            <!-- Hints -->
            <h2>Hints</h2>
            <!-- Button clicked => call revealHint function from .js file -->
            <button class="button" onclick="revealHint()">Reveal Hint?</button>
            <div id="hints"> 
                <!-- Each hint is hidden, displayed only when function is called -->
                <p class="hint" style="display: none;">Hint 1: Enter some HTML into the search bar and see what happens</p>
                <p class="hint" style="display: none;">Hint 2: There is a specific HTML tag used for running JavaScript</p>
                <p class="hint" style="display: none;">Hint 3: The payload uses an alert function</p>
            </div>
        
        </div>

        <!-- Solution -->
        <div class="description">
            <h2>Solution</h2>
            <!-- Button clicked => call revealSolution function from .js file -->
            <button class="button" onclick="revealSolution()">Reveal Solution</button>
            <!-- Solution is hidden, displayed only when function is called -->
            <div id="solution" style="display: none;">
                <!-- Solution text -->
                <p> 
                > Enter the following payload into the search bar: &ltscript&gtalert('text')&lt/script&gt;</p>

        </div>
   
    </body>

</html>
