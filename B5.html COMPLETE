<!-- Beginner Task 5 -->
<!DOCTYPE html>
<html>
  
    <head>
        <!-- Tab title -->
        <title>CyberBreach Labs - Beginner: Task 5</title>
        <!-- Link to stylesheet -->
        <link rel="stylesheet" href="/static/style.css">
        <!-- Link to JavaScript file -->
        <script src="{{ url_for('static', filename='labs.js') }}"></script>
    </head>
  
    <body>
        <!-- Task number and difficulty -->
        <h1>Beginner: Task 5</h1>
        
        <!-- Navigation -->      
        <nav>
            <a href="/">Home</a>
            <a href="/account">Account</a>
            <a href="/labs">Labs</a>
            <!-- Added link: difficulty page -->
            <a href="/labs/beginner">Beginner Labs</a>
        </nav>

        <div class="description">
            <!-- Task title -->
            <h2>Security Misconfigurations</h2>
            <!-- Descition of vulnerability and task -->
            <p>Security misconfigurations are extremely common and arise due to implementation flaws, incomplete settings <br>
               and unpatched software which can all be exploited quite easily by attackers. The misconfigurations can create <br>
                entry points for automated attacks which can lead to unauthorised users gaining full control of the system.<br>
            <br>In this lab, you will have access to the web application for Book Nook, where users can browse, buy <br>
            and wishlist books. However, the site has been deployed too early and the developers were very sloppy.<br> 
            The phpMyAdmin database management panel is accessible to the public and the credentials are still set the the default.
            <br><br>
            Task: Capture the Flag ! Just login with the default credentials to access the management panel.
            <br><br>
            </p>
            <!-- Button to start lab, opens a new tab -->
            <a href="/labs/beginner/B5/B5task" target="_blank" class="button">Start Lab</a>
            
            <!-- Flag submission -->
            <br><br>Submit Flag:
            <form method="POST" action="/submitFlag">
                <!-- Task ID for progress bar -->
                <input type="hidden" name="taskID" value="B5">
                <!-- Correct flag value -->
                <input type="hidden" name="taskFlag" value="security_config_sc1c1">
                <!-- User flag submission -->
                <input type="text" name="userFlag" placeholder="FLAG" autocomplete="off" required>
                <!-- Submission Button -->
                <button type="submit" class="button">Submit Flag</button>
            </form>

            <!-- Jinja2: Flash messages -->
            <!-- Calls Flash function [backend] and pulls messages from storage -->
            {% with messages = get_flashed_messages(with_categories=true) %} 
                {% for category, message in messages %}
                    <!-- If error message, display in red. If not, display in green -->
                    <p class="{{ 'errorMessage' if category == 'error' else 'successMessage' }}">{{ message }}</p>
                {% endfor %}
            {% endwith %}
            
        </div>

        <div class="description">
            <!-- Hints -->
            <h2>Hints</h2>
            <!-- Button clicked => call revealHint function from .js file -->
            <button class="button" onclick="revealHint()">Reveal Hint?</button>
            <div id="hints"> 
                <!-- Each hint is hidden, displayed only when function is called -->
                <p class="hint" style="display: none;">Hint 1: Database management panels are commonly set up with well known default credentials</p>
                <p class="hint" style="display: none;">Hint 2: The default database username is the superuser which is commonly called _ _ _ _</p>
                <p class="hint" style="display: none;">Hint 3: Often, default installations have no password set</p>
            
            </div>
        
        </div>

        <!-- Solution -->
        <div class="description">
            <h2>Solution</h2>
            <!-- Button clicked => call revealSolution function from .js file -->
            <button class="button" onclick="revealSolution()">Reveal Solution</button>
            <!-- Solution is hidden, displayed only when function is called -->
            <div id="solution" style="display: none;">
                <!-- Solution text -->
                <p> 
                > The default database credentials are: username: root    password: (empty)</p>

        </div>
   
    </body>

</html>
