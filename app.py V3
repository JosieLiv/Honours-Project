@myWebApp.route('/submitFlag', methods=['POST'])
def submitFlag():
    # if user is not logged in, redirect to login page and display message
    if 'user_id' not in session:
        flash('You are required to log in before accessing the labs.', 'error')
        return redirect(url_for('account'))
    userFlag = request.form['userFlag']
    taskFlag = request.form['taskFlag']
    taskID = request.form['taskID']
    connection = database()
    cursor = connection.cursor()
    cursor.execute('SELECT * FROM progress WHERE userID = %s AND taskID = %s', (session['user_id'], taskID))
    completed = cursor.fetchone()
    if completed:
        flash('You have already completed this task!', 'error')
    elif userFlag == taskFlag:
        cursor.execute ('UPDATE scores SET score = score + 100 WHERE userID = %s', (session['user_id']))
        cursor.execute('INSERT INTO progress (userID, taskID) VALUES (%s, %s)', (session['user_id'], taskID))
        connection.commit()
        flash('Correct flag! You have earned 100 points!')
    else:
        flash('Incorrect flag', 'error')
    connection.close()
    return redirect(request.referrer)

