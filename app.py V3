@myWebApp.route('/account', methods=['GET', 'POST'])
def account():
    error = None
    if request.method == 'POST':
        action = request.form.get('action')
        if action == 'register':
            username = request.form['username']
            email = request.form['email']
            password = generate_password_hash(request.form['password'])
            if len(username) <3 or len(username) >20:
                flash('Username must be between 3 and 20 characters long')
            elif len(password) <8:
                flash('Password must be at least 8 characters long')
            elif '@' not in email:
                flash('Please enter a valid email')
            else:
                connection = database()
                cursor = connection.cursor()
                # check if email has already been registered 
                cursor.execute('SELECT * FROM users WHERE email = %s', (email,))
                user_exists = cursor.fetchone()
                if user_exists:
                    flash('This email has already been registered. Please login or use another email', 'error')
                else:
                    cursor.execute('INSERT INTO users (username, email, password) VALUES (%s, %s, %s)', (username, email, password))
                    connection.commit()
                    cursor.execute('SELECT userID FROM users WHERE email = %s', (email,))
                    new = cursor.fetchone()
                    cursor.execute('INSERT INTO scores (userID, score) VALUES (%s, %s)', (new['userID'], 0))
                    flash('Success! Account has been created, please login.')
                    connection.commit()
                connection.close()   
        elif action == 'login':
            email = request.form['email']
            password = request.form['password']
            connection = database()
            cursor = connection.cursor()
            cursor.execute('SELECT * FROM users WHERE email = %s', (email,))
            user = cursor.fetchone()
            connection.close()
            if user and check_password_hash(user['password'], password):
                session['user_id'] = user['userID']
                session['username'] = user['username']
                return redirect(url_for('account'))
            else:
                flash('Invalid login details. Please try again.', 'error')     
    if 'user_id' in session:
        connection = database()
        cursor = connection.cursor()
        cursor.execute('SELECT * FROM users WHERE userID = %s', (session['user_id'],))
        user = cursor.fetchone()
        cursor.execute('SELECT score FROM scores WHERE userID =%s', (session['user_id'],))
        score = cursor.fetchone()
        cursor.execute('SELECT COUNT(*) as total FROM progress WHERE userID =%s', (session['user_id'],))
        total = cursor.fetchone()
        percent = round(total['total'] / 18 * 100)

        cursor.execute('''SELECT users.username, scores.score FROM users 
        JOIN scores ON users.userID = scores.userID 
        ORDER BY scores.score DESC LIMIT 10''')
        leaderboard = cursor.fetchall()

        connection.close()
        return render_template('account.html', user=user, score=score, total=total, percent=percent, leaderboard=leaderboard, error=error)  
    return render_template('account.html', user=None)
    


